# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Security: comma-separated Telegram user IDs allowed to use the bot
ALLOWED_USER_IDS=your_telegram_user_id

# Workspace root directory the bot operates in
WORKSPACE_ROOT=/home/user/projects

# IDE Profile: antigravity, cursor, vscode, windsurf
IDE_PROFILE=antigravity

# CDP port (leave empty to auto-scan ports 9222, 9223, 9333, 9444, 9555, 9666)
CDP_PORT=

# Timeout waiting for AI response from IDE (seconds)
RESPONSE_TIMEOUT=120

# Command execution timeout in seconds
COMMAND_TIMEOUT=60
